# LLM Stack Configuration
# Copy this to .env and update with your values

# ===== Server Hosts =====
BLACKWELL_HOST=blackwell
A30_HOST=a30

# ===== Model Storage =====
MODELS_PATH=/models
HF_CACHE=/root/.cache/huggingface

# ===== HuggingFace =====
HF_TOKEN=

# ===== LiteLLM Router =====
LITELLM_PORT=4000
LITELLM_HOST=0.0.0.0
LITELLM_LOG_LEVEL=INFO

# ===== vLLM Common Settings =====
VLLM_LOG_LEVEL=INFO
VLLM_ENABLE_CUDA_COMPATIBILITY=1

# ===== Tool Calling / MCP-ready (per-model) =====
# These flags enable OpenAI tools/function-calling in vLLM for compatible models.
# MCP tools are passed by the client over the OpenAI API; vLLM must support tool calling.
LLAMA33_TOOL_ARGS=--enable-auto-tool-choice --tool-call-parser llama3_json
QWEN36_TOOL_ARGS=--enable-auto-tool-choice --tool-call-parser hermes
MIMO25BW_TOOL_ARGS=--enable-auto-tool-choice --tool-call-parser hermes
MIMO_TOOL_ARGS=--enable-auto-tool-choice --tool-call-parser hermes
# LLaVA does not have a reliable default tool parser in this stack; keep empty unless tested.
LLAVA_TOOL_ARGS=
DEEPSEEK_TOOL_ARGS=--enable-auto-tool-choice --tool-call-parser hermes

# ===== Blackwell GPU Settings =====
BLACKWELL_CUDA_VISIBLE_DEVICES=0,1
BLACKWELL_SHARED_MEM=16gb

# Llama 3.3 70B AWQ (GPU 0)
LLAMA33_GPU=0
LLAMA33_PORT=8001
LLAMA33_GPU_MEMORY_UTILIZATION=0.90
LLAMA33_MAX_MODEL_LEN=65536

# Qwen 3.6 27B (GPU 1)
QWEN36_GPU=1
QWEN36_PORT=8002
QWEN36_GPU_MEMORY_UTILIZATION=0.90
QWEN36_MAX_MODEL_LEN=32768

# MiMo V2.5 on Blackwell (experimental, uses both Blackwell GPUs + CPU offload)
MIMO25BW_GPUS=0,1
MIMO25BW_PORT=8006
MIMO25BW_TENSOR_PARALLEL_SIZE=2
MIMO25BW_GPU_MEMORY_UTILIZATION=0.92
MIMO25BW_MAX_MODEL_LEN=16384
MIMO25BW_CPU_OFFLOAD_GB=160
MIMO25BW_SWAP_SPACE_GB=64

# ===== A30 GPU Settings =====
A30_SHARED_MEM=24gb

# MiMo 7B RL (official XiaomiMiMo, fits in A30)
MIMO_GPUS=0
MIMO_PORT=8003
MIMO_TENSOR_PARALLEL_SIZE=1
MIMO_GPU_MEMORY_UTILIZATION=0.85
MIMO_MAX_MODEL_LEN=32768

# LLaVA v1.6 Vicuna 7B (GPU 2)
LLAVA_GPU=2
LLAVA_PORT=8004
LLAVA_GPU_MEMORY_UTILIZATION=0.85
LLAVA_MAX_MODEL_LEN=4096

# DeepSeek R1 Distill Qwen 14B (~28GB BF16, GPU 0+1, alternative to MIMO)
DEEPSEEK_GPUS=0,1
DEEPSEEK_PORT=8005
DEEPSEEK_TENSOR_PARALLEL_SIZE=2
DEEPSEEK_GPU_MEMORY_UTILIZATION=0.85
DEEPSEEK_MAX_MODEL_LEN=32768

# ===== Monitoring =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=15d
