# LLM Stack Configuration
# Copy this to .env and update with your values

# ===== Server Hosts =====
BLACKWELL_HOST=blackwell
A30_HOST=a30

# ===== Model Storage =====
MODELS_PATH=/models
HF_CACHE=/root/.cache/huggingface

# ===== HuggingFace =====
HF_TOKEN=

# ===== LiteLLM Router =====
LITELLM_PORT=4000
LITELLM_HOST=0.0.0.0
LITELLM_LOG_LEVEL=INFO

# ===== vLLM Common Settings =====
VLLM_LOG_LEVEL=INFO
VLLM_ENABLE_CUDA_COMPATIBILITY=1

# ===== Blackwell GPU Settings =====
BLACKWELL_CUDA_VISIBLE_DEVICES=0,1
BLACKWELL_SHARED_MEM=16gb

# Llama 3.3 (GPU 0)
LLAMA33_GPU=0
LLAMA33_PORT=8001
LLAMA33_GPU_MEMORY_UTILIZATION=0.90
LLAMA33_MAX_MODEL_LEN=65536

# Qwen 3.6 (GPU 1)
QWEN36_GPU=1
QWEN36_PORT=8002
QWEN36_GPU_MEMORY_UTILIZATION=0.90
QWEN36_MAX_MODEL_LEN=65536

# ===== A30 GPU Settings =====
A30_SHARED_MEM=24gb

# MIMO (GPU 0+1, tensor-parallel)
MIMO_GPUS=0,1
MIMO_PORT=8003
MIMO_TENSOR_PARALLEL_SIZE=2
MIMO_GPU_MEMORY_UTILIZATION=0.88
MIMO_MAX_MODEL_LEN=32768

# LLaVA (GPU 2)
LLAVA_GPU=2
LLAVA_PORT=8004
LLAVA_GPU_MEMORY_UTILIZATION=0.85
LLAVA_MAX_MODEL_LEN=16384

# DeepSeek (GPU 0+1, alternative to MIMO)
DEEPSEEK_GPUS=0,1
DEEPSEEK_PORT=8005
DEEPSEEK_TENSOR_PARALLEL_SIZE=2
DEEPSEEK_GPU_MEMORY_UTILIZATION=0.88
DEEPSEEK_MAX_MODEL_LEN=32768

# ===== Monitoring =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=15d
